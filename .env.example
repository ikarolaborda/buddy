APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Provider Keys (used by laravel/ai)
OPENAI_API_KEY=

# Buddy Configuration
BUDDY_MODEL=gpt-5.4
BUDDY_EMBEDDING_MODEL=text-embedding-3-small
BUDDY_MAX_EVALUATION_STEPS=10
BUDDY_EVALUATION_TIMEOUT=120

# Buddy API Authentication
BUDDY_API_AUTH=true
BUDDY_API_KEY_PEPPER=

# Buddy Memory Backend (legacy | hub | shadow)
BUDDY_MEMORY_BACKEND=legacy
BUDDY_MEMORY_HUB_URL=http://localhost:8090
BUDDY_MEMORY_HUB_TOKEN=
BUDDY_MEMORY_HUB_PROJECT=buddy

# LangSmith Observability (tracing of agent runs)
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=buddy-local
LANGSMITH_TRACING=false
LANGSMITH_SEND_PROMPTS=false
LANGSMITH_TIMEOUT=2

# Buddy Timeout Ordering: provider < job < worker < retry_after
BUDDY_PROVIDER_TIMEOUT=120
BUDDY_JOB_TIMEOUT=180
BUDDY_WORKER_TIMEOUT=210
BUDDY_QUEUE_RETRY_AFTER=240
BUDDY_TASK_LEASE_SECONDS=300

# Qdrant Configuration
QDRANT_HOST=http://localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=buddy_episodes
QDRANT_KNOWLEDGE_COLLECTION=buddy_knowledge
QDRANT_VECTOR_SIZE=1536
